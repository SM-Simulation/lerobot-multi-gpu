+    def _init_fast_cache(self):
+        """Load numpy arrays and pre-convert to shared-memory tensors once.
+        Safe to call multiple times — only runs on first invocation.
+        When DataLoader forks workers, they inherit these via copy-on-write."""
+        import numpy as np
+        if hasattr(self, '_np_cache'):
+            return
+        self._np_cache = {
+            'indices':         np.load('/dev/shm/indices.npy'),
+            'episode_indices': np.load('/dev/shm/episode_indices.npy'),
+            'frame_indices':   np.load('/dev/shm/frame_indices.npy'),
+            'timestamps':      np.load('/dev/shm/timestamps.npy'),
+            'task_indices':    np.load('/dev/shm/task_indices.npy'),
+        }
+        # Pre-convert to tensors in shared memory so forked workers get zero-copy access
+        imgs = np.load('/dev/shm/images.npy')  # (N, 240, 320, 3) uint8
+        self._images_tensor = torch.from_numpy(
+            imgs.transpose(0, 3, 1, 2).astype(np.float32) / 255.0
+        ).share_memory_()
+        self._actions_tensor = torch.from_numpy(
+            np.load('/dev/shm/actions.npy').copy()
+        ).share_memory_()
+        self._states_tensor = torch.from_numpy(
+            np.load('/dev/shm/states.npy').copy()
+        ).share_memory_()
+        del imgs
